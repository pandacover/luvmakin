---
import Layout from '../layouts/Layout.astro';
import { getProjects } from '../lib/projects';

const projects = await getProjects();
---

<Layout
	title="projects — luv makin"
	description="Open source projects and side work in frontend engineering, workflow systems, and developer tools."
>
	<div class="content-area" style="padding-top: 6rem;">
		<section class="section reveal-on-scroll">
			<h2 class="section-title">projects</h2>
			{projects.map((project) => (
				<div class="project-card">
					<a href={project.url} target="_blank" rel="noopener noreferrer" class="project-name">{project.name}</a>
					{project.summary && <p class="project-description">{project.summary}</p>}
				</div>
			))}
		</section>
	</div>
</Layout>