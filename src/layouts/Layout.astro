---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	pathname?: string;
}

const { title, description, pathname = '/' } = Astro.props;
const currentPath = pathname.replace(/\/$/, '') || '/';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" href="/profile-picture.jpg" type="image/jpeg" />
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body>
		<div class="page">
			<main class="content">
				<slot />
			</main>
			<aside class="sidebar">
				<nav class="nav" aria-label="Main navigation">
					{currentPath === '/' ? (
						<span class="nav-link active" data-key="h"><span class="nav-key">[h]</span> home</span>
					) : (
						<a href="/" class="nav-link" data-key="h"><span class="nav-key">[h]</span> home</a>
					)}
					{currentPath === '/blog' ? (
						<span class="nav-link active" data-key="b"><span class="nav-key">[b]</span> blog</span>
					) : (
						<a href="/blog" class="nav-link" data-key="b"><span class="nav-key">[b]</span> blog</a>
					)}
					{currentPath === '/projects' ? (
						<span class="nav-link active" data-key="p"><span class="nav-key">[p]</span> projects</span>
					) : (
						<a href="/projects" class="nav-link" data-key="p"><span class="nav-key">[p]</span> projects</a>
					)}
				</nav>
				<div class="links">
					<a href="https://github.com/pandacover" target="_blank" rel="noopener noreferrer" data-key="g"><span class="nav-key">[g]</span> github</a>
					<a href="https://www.linkedin.com/in/luvmakin/" target="_blank" rel="noopener noreferrer" data-key="l"><span class="nav-key">[l]</span> linkedin</a>
					<a href="https://x.com/flexaboiL" target="_blank" rel="noopener noreferrer" data-key="x"><span class="nav-key">[x]</span> x</a>
				</div>
			</aside>
		</div>
		<script>
			document.addEventListener('keydown', (e) => {
				if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
				const key = e.key.toLowerCase();
				const path = window.location.pathname.replace(/\/$/, '') || '/';
				if (key === 'h' && path !== '/') { window.location.href = '/'; e.preventDefault(); }
				if (key === 'b' && path !== '/blog') { window.location.href = '/blog'; e.preventDefault(); }
				if (key === 'p' && path !== '/projects') { window.location.href = '/projects'; e.preventDefault(); }
				if (key === 'g') { window.open('https://github.com/pandacover', '_blank'); e.preventDefault(); }
				if (key === 'l') { window.open('https://www.linkedin.com/in/luvmakin/', '_blank'); e.preventDefault(); }
				if (key === 'x') { window.open('https://x.com/flexaboiL', '_blank'); e.preventDefault(); }
			});
		</script>
	</body>
</html>
